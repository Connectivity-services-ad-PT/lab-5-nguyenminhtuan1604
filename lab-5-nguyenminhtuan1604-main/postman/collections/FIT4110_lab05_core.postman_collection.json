                  "  pm.expect(json).to.have.property('policyId');",
                  "});",
                  "pm.test('Response có allowedRoles array', function() {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('allowedRoles');",
                  "  pm.expect(json.allowedRoles).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
