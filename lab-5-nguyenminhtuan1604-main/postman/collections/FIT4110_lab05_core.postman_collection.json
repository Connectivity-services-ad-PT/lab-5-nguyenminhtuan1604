                  "pm.test('Status 201 Created', function() { pm.response.to.have.status(201); });",
                  "pm.test('Response có logId', function() {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('logId');",
                  "});",
                  "pm.test('Response có acceptedAt', function() {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('acceptedAt');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
