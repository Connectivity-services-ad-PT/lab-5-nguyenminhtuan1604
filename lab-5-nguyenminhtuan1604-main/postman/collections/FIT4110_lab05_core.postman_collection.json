          ]
        },
        {
          "name": "POST /access-log — Gửi log ALLOW",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardId\": \"RFID-2026-001\",\n  \"gateId\": \"GATE-01\",\n  \"direction\": \"ENTER\",\n  \"decision\": \"ALLOW\",\n  \"reason\": null,\n  \"timestamp\": \"2026-05-10T08:00:00Z\"\n}"
            },
