{
  "info": {
    "name": "FIT4110 Lab03 — Core Business Policy API (pair10)",
    "description": "Bộ kiểm thử cho Core Business Policy API (pair10). Consumer: Access Gate. Provider: Core Business.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4010"
    },
    {
      "key": "authToken",
      "value": "lab-token"
    }
  ],
  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "GET /health — Service còn sống",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Response có status ok', function() {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});",
                  "pm.test('Response có service name', function() {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('service');",
                  "  pm.expect(json.service).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /policy/access-check — ALLOW",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardId\": \"RFID-2026-001\",\n  \"gateId\": \"GATE-01\",\n  \"direction\": \"ENTER\",\n  \"timestamp\": \"2026-05-10T08:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/policy/access-check",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "policy",
                "access-check"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Response có decision', function() {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('decision');",
                  "  pm.expect(['ALLOW', 'DENY']).to.include(json.decision);",
                  "});",
                  "pm.test('Response có policyId', function() {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('policyId');",
                  "});",
                  "pm.test('Response có cardId và gateId', function() {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('cardId');",
                  "  pm.expect(json).to.have.property('gateId');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /policy/rules — Danh sách rules",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/policy/rules",
