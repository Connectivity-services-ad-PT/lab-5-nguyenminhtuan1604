              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "policy",
                "rules",
                "POL-9999-999"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('policyId không tồn tại: mock trả 200/404, service thật trả 404', function() {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Ghi chú: mock không validate business logic, service thật sẽ trả 404', function() {",
                  "  pm.expect(true).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
